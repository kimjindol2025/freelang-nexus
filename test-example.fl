@lang(rust)
---
#[no_mangle]
pub extern "C" fn add(a: i32, b: i32) -> i32 { a + b }
#[no_mangle]
pub extern "C" fn multiply(x: i32, y: i32) -> i32 { x * y }
---

@lang(go)
---
//export AddNumbers
func AddNumbers(a int, b int) int {
  return a + b
}

//export MultiplyNumbers
func MultiplyNumbers(x int, y int) int {
  return x * y
}
---

@lang(python)
---
def greet(name):
  return "Hello " + name

def add_numbers(a, b):
  return a + b
---

@lang(c)
---
int add(int a, int b) { return a + b; }
double multiply(double x, double y) { return x * y; }
---
